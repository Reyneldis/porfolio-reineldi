---
import Layout from '../layouts/Layout.astro';
import SocialLink from '../components/SocialLink.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import RevealOnScroll from '../components/RevealOnScroll.astro';
---

<Layout
  title="Reineldi Umpierre - Desarrollador Web"
  description="Contrata a Umpi para crear tu aplicación web. Desarrollador Web, especialista en desarrollar tu gusto."
>
  <section
    id="home"
    class="relative flex items-center flex-grow pt-20 overflow-hidden md:min-h-screen"
  >
    <div class="container relative z-10 px-6 mx-auto md:px-12 lg:px-40">
      <div class="max-w-4xl">
        <div
          class="flex flex-col items-start gap-4 mb-6 sm:flex-row sm:items-center animate-fade-in"
        >
          <img
            src="/images/avatar.webp"
            alt="Avatar de Reineldi Umpierre"
            class="object-cover w-24 h-24 border-4 rounded-full shadow-xl border-slate-200 dark:border-slate-700 float-animation"
            width={96}
            height={96}
            loading="eager"
          />
          <div class="flex flex-col gap-2">
            <a
              href="#contact"
              class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white transition-all duration-300 transform rounded-full shadow-lg bg-gradient-to-r from-green-400 to-green-600 hover:from-green-500 hover:to-green-700 hover:scale-105 hover:shadow-green-500/50"
            >
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                  clip-rule="evenodd"></path>
              </svg>
              Disponible para trabajar
            </a>
            <!-- Accesibilidad corregida: dark:text-slate-300 -->
            <p class="text-sm text-slate-500 dark:text-slate-300">
              Respuesta en menos de 24h
            </p>
          </div>
        </div>

        <h1
          class="mb-4 font-extrabold text-slate-900 dark:text-white font-display animate-slide-up"
          style="animation-delay: 0.1s; font-size: clamp(2.5rem, 5vw, 4rem);"
        >
          <!-- Accesibilidad corregida: dark:text-orange-300 -->
          <span
            class="block text-blue-600 dark:text-orange-300"
            style="font-size: clamp(1.5rem, 4vw, 2.5rem);"
            >👋 Soy Reineldi.</span
          >
        </h1>

        <p
          class="max-w-xl mb-8 font-sans leading-relaxed text-slate-500 dark:text-slate-300 animate-slide-up"
          style="animation-delay: 0.2s; font-size: clamp(1rem, 2vw, 1.25rem);"
        >
          Ingeniero Informático y <span
            class="font-bold text-orange-500 dark:text-orange-300"
            >Desarrollador Web</span
          >, enfocado en construir experiencias digitales rápidas, accesibles y
          con un diseño impecable.
        </p>

        <div
          class="flex items-center gap-4 mb-12 animate-slide-up md:mb-0"
          style="animation-delay: 0.3s;"
        >
          <SocialLink href="https://github.com/Reyneldis" iconName="github" />
          <SocialLink
            href="https://www.instagram.com/neldis77/"
            iconName="instagram"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>

<RevealOnScroll>
  <ExperienceSection />
</RevealOnScroll>
<RevealOnScroll>
  <ProjectsSection />
</RevealOnScroll>
<RevealOnScroll>
  <AboutSection />
</RevealOnScroll>
<RevealOnScroll>
  <ContactSection />
</RevealOnScroll>
<RevealOnScroll>
  <Footer />
</RevealOnScroll>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fade-in 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .animate-slide-up {
    animation: slide-up 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
  }
</style>
